# Required
OPENAI_API_KEY=sk-...
GEMINI_API_KEY=AI...

# Email (transactional notifications — admin signup alerts, invite links). Uses
# Resend (resend.com). EMAIL_API_KEY is the Resend API key; unset = emails are
# skipped (logged + dropped), the app still runs. EMAIL_FROM is the sender; it must
# be on a domain verified in Resend (seroapp.com is verified). If yours isn't yet, you
# can send from Resend's sandbox: EMAIL_FROM="Sero <onboarding@resend.dev>".
# EMAIL_API_KEY=re_...
# EMAIL_FROM="Sero <notifications@seroapp.com>"
# Public base URL, used to build the clickable /join link in invite emails. Optional —
# if unset it's derived from the incoming request (works local + live). Set it on Render
# to be safe behind the proxy, e.g. https://sero-obwq.onrender.com
# APP_BASE_URL=https://sero-obwq.onrender.com

# Optional
# Postgres connection string. When set, app data is stored in Postgres; when
# unset, the app falls back to on-disk JSON files (no DB needed).
# Get a free one from a managed provider (e.g. Neon) and paste it here in your
# own .env (never commit the real .env — it is gitignored).
# LIVE and LOCAL are SEPARATE databases (postgres-runtime-data): the live app
# points at the main Neon database; local dev points at a second Neon database
# (or any local Postgres). Never share one URL across both.
# DATABASE_URL=postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require

# Which environment this process IS: "local" (dev machine) or "live" (deployed).
# Unset defaults to local (or live when NODE_ENV=production). The database
# remembers which environment first claimed it and the app REFUSES to start on a
# mismatch — that's the safety catch that stops a copied .env from pointing local
# dev at the live database. ALLOW_ENV_MISMATCH=1 overrides it (backfill only).
# APP_ENV=local

# Parking spot for the LIVE database's connection string on a dev machine. The app
# never reads this — at deploy time it becomes the live environment's DATABASE_URL
# (paired with APP_ENV=live).
# LIVE_DATABASE_URL=postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require
# Session TTL in milliseconds. Defaults to 2 hours (7200000).
# Increase for long meetings; decrease for tighter testing.
SESSION_TTL_MS=7200000

# Superadmin allowlist (pre-go-live PG6). Comma-separated emails matched against
# the server-resolved account email — this is the ONLY thing that clears the
# cross-company /api/v1/admin/* gate. Empty/unset = nobody is superadmin.
# Keep this to the single owner account.
SUPERADMIN_EMAILS=carl@seroteams.com

# Optional engine / dev knobs — all have safe defaults; set only to override.
# AI_MAX_CONCURRENCY   — cap on simultaneous live AI calls (default 4; ai-guard.ts).
# GUEST_RUNS_PER_DAY   — shared daily budget of no-account guest runs (default 10).
# OPENAI_MODEL         — override the default OpenAI model id (models.ts).
# RUN_FILE_ECHO        — "1" keeps writing run artifacts to disk alongside Postgres
#                        (the rollback path); unset = DB only in live.
# DEV_AUTOLOGIN        — dev-only: skip the login screen with a seeded session.
# SERO_ENV             — legacy alias for APP_ENV (above); prefer APP_ENV.

# Dev-only login prefill on the login screen (stripped from production builds).
# Set these in your own .env to get the one-click prefill that cycles the three test
# logins — Manager (default, the real end user) → Admin (internal) → Member (team
# member). Leave a pair unset and that account drops out of the cycle; leave all unset
# and the prefill simply doesn't appear. No credentials live in source.
# VITE_DEV_LOGIN_MANAGER_EMAIL=manager@example.com
# VITE_DEV_LOGIN_MANAGER_PASSWORD=...
# VITE_DEV_LOGIN_ADMIN_EMAIL=admin@example.com
# VITE_DEV_LOGIN_ADMIN_PASSWORD=...
# VITE_DEV_LOGIN_MEMBER_EMAIL=member@example.com
# VITE_DEV_LOGIN_MEMBER_PASSWORD=...
