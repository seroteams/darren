# Required
OPENAI_API_KEY=sk-...
GEMINI_API_KEY=AI...

# Optional
# Postgres connection string (Phase 005). When set, sessions/users are stored in
# Postgres; when unset, the app falls back to on-disk JSON files (no DB needed).
# Get a free one from a managed provider (e.g. Neon) and paste it here in your
# own .env (never commit the real .env — it is gitignored).
# DATABASE_URL=postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require
# Session TTL in milliseconds. Defaults to 2 hours (7200000).
# Increase for long meetings; decrease for tighter testing.
SESSION_TTL_MS=7200000
