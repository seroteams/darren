# Required
OPENAI_API_KEY=sk-...
GEMINI_API_KEY=AI...

# Optional
# Postgres connection string (Phase 005). When set, sessions/users are stored in
# Postgres; when unset, the app falls back to on-disk JSON files (no DB needed).
# Get a free one from a managed provider (e.g. Neon) and paste it here in your
# own .env (never commit the real .env — it is gitignored).
# DATABASE_URL=postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require
# Session TTL in milliseconds. Defaults to 2 hours (7200000).
# Increase for long meetings; decrease for tighter testing.
SESSION_TTL_MS=7200000

# Dev-only login prefill on the login screen (stripped from production builds).
# Set these in your own .env to get the one-click Admin / Standard-user swap
# while testing locally; leave unset and the prefill simply doesn't appear.
# No credentials live in source.
# VITE_DEV_LOGIN_EMAIL=you@example.com
# VITE_DEV_LOGIN_PASSWORD=...
# VITE_DEV_LOGIN_MEMBER_EMAIL=member@example.com
# VITE_DEV_LOGIN_MEMBER_PASSWORD=...
