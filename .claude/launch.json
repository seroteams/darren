{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "sero-dev",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "port": 3000
    },
    {
      "name": "verdict-review",
      "runtimeExecutable": "node",
      "runtimeArgs": ["scripts/serve-static.js", "logs/benchmark/messy-12", "4178"],
      "port": 4178
    },
    {
      "name": "sero-web",
      "runtimeExecutable": "node",
      "runtimeArgs": ["node_modules/vite/bin/vite.js", "--port", "3000", "--strictPort"],
      "port": 3000
    },
    {
      "name": "sero-api",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["cross-env", "API_PORT=3001", "node", "backend/api/server.ts"],
      "port": 3001
    },
    {
      "name": "sero-web-alt",
      "runtimeExecutable": "node",
      "runtimeArgs": ["node_modules/vite/bin/vite.js", "--port", "3007", "--strictPort"],
      "port": 3007
    },
    {
      "name": "sero-web-3009",
      "runtimeExecutable": "node",
      "runtimeArgs": ["node_modules/vite/bin/vite.js", "--port", "3009", "--strictPort"],
      "port": 3009
    },
    {
      "name": "sero-web-3011",
      "runtimeExecutable": "node",
      "runtimeArgs": ["node_modules/vite/bin/vite.js", "--port", "3011", "--strictPort"],
      "port": 3011
    },
    {
      "name": "sero-prod-iso",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["cross-env", "NODE_ENV=production", "node", "backend/api/server.js"],
      "port": 3098,
      "autoPort": true
    }
  ]
}
