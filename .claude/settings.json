{
  "permissions": {
    "allow": [
      "WebSearch",
      "WebFetch(domain:raw.githubusercontent.com)",
      "Bash(npm install *)",
      "Bash(gh --version)",
      "Bash(git --version)",
      "Bash(git init *)",
      "Bash(git branch *)",
      "Bash(git remote *)",
      "Bash(git add *)",
      "Bash(git -c user.email=\"carl@seroteams.com\" -c user.name=\"Carl Heaton\" commit -m \"Initial commit\")",
      "Bash(git push *)",
      "Bash(grep -iE \"\\\\.env$|\\\\.env\\\\..*|secret|credential|api.?key|\\\\.pem$|\\\\.key$\")",
      "Bash(git check-ignore *)",
      "Bash(git commit -m ' *)",
      "Bash(git push origin main)",
      "Bash(curl -s -H \"Authorization: Bearer $KEY\" https://api.render.com/v1/*)",
      "Bash(curl -s -m * -H \"Authorization: Bearer $KEY\" https://api.render.com/v1/*)",
      "Read(//c/Users/User/.claude/**)"
    ]
  },
  "outputStyle": "Carl",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/lane-check.js"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -Command \"[Console]::OutputEncoding=[Text.Encoding]::UTF8; Write-Output '[LANE BOARD] This folder is shared by parallel chats. As soon as your work area is clear, claim a lane: add a row to LANES.md (session = first 8 chars of your session id, narrow paths, today''s date). Remove your row when the work is committed. Full rules in LANES.md.'\""
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -Command \"[Console]::OutputEncoding=[Text.Encoding]::UTF8; Get-Content -Raw -Encoding UTF8 '.claude/hooks/guardrails-reminder.txt'\""
          }
        ]
      }
    ]
  },
  "enabledPlugins": {}
}
