node_modules
admin/dist
.env
.env.local

# Local credentials for outside services (Render API key etc.) — never committed
.secrets/
# Database dumps from scripts/backup-db.js — local-only, never in git history
backups/
.DS_Store
*.zip
!docs/archive/**/*.zip
# …except the full June log archive: 43MB, local-only (too big for git history)
docs/archive/logs/logs-june-2026-full.zip
.playwright-mcp/

# Night-test report is markdown-first (docs/reports/*-night-test-report.md); the generated
# HTML dashboard twin isn't tracked (no dup .html/.md of the same report).
docs/reports/*-night-test-report.html

# Local / runtime agent & tool artifacts
.*.out
.inspect.js
.claude/settings.local.json
.claude/scheduled_tasks.lock
.impeccable/
content/lexicons/_suggested/
admin/node_modules/.vite/

# Daily work reports
REPORT-*.md
CHEATSHEET-*.md

# Per-person profiles (derived from logs/ — rebuild with scripts/rebuild-profiles.js)
content/data/people/

# Tester feedback (009 Phase 5) — a local runtime store Carl reads directly; may carry
# HR-adjacent notes, so it's never committed.
content/data/feedback/

# Superadmin access audit (pre-go-live PG6) — one JSONL line per cross-company access.
# A local runtime trail, never committed.
content/data/audit/

# Manager 1:1 ratings (pre-go-live PG3) — a rating.json sidecar per run. The optional
# note is a private manager field (HR-adjacent), so belt-and-braces never commit it.
# (Run folders live under logs/** which is already ignored; this covers any keep-set too.)
**/rating.json

# Manager people-aliases (pre-go-live PG9) — a per-manager merge/rename sidecar. Personal
# (real names), so never committed.
content/data/people-aliases/

# Guest daily-cap counter (guest-run Phase 1) — a {date, count} runtime file, never committed.
content/data/guest-cap.json

# Runtime logs — fully ignored, NO keep-set. The old keep-set committed real
# employee names/notes/briefings into the repo; untracked here so they leave HEAD
# and every future clone (personal-data-security Phase 3, interim). The full scrub
# of them from past history is still pending — see docs/plans/doing/personal-data-security/phase-3.md.
debug-be19bb.log
.cursor/debug-*.log
logs/**

# Runtime-generated questions. The engine writes source:generated questions to the
# questions ROOT during runs; authored banks live in the _seed/_intro/_runtime
# subdirs (tracked), so this root-only glob never hides real content.
/content/questions/*.yaml

# Local screenshots dropped at repo root (UI reference shots, etc.)
/*.png

# Chat-history archive — generated transcripts + generator, kept on the local
# machine only (re-runnable, never committed; ~5.7MB of past conversation logs)
/docs/chat-history/
/scripts/chat-log.py
frontend/dist

# Screen-gallery static snapshots (screen-gallery Phase 2 v2) — generated build artifacts,
# ~26MB with fonts inlined. Regenerate with `node scripts/gallery-export.mjs` (dev server up).
# The README + export script + fixtures are tracked; the generated .html is not.
/docs/screen-gallery/*.html
