{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "types": ["node"],

    "strict": true,
    "noImplicitAny": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "noFallthroughCasesInSwitch": true,
    "forceConsistentCasingInFileNames": true,

    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "allowJs": false
  },
  "//": "admin/ has its own tsconfig (browser/DOM); this root config is Node/back-end only.",
  "include": ["backend/**/*.ts", "backend/**/*.mts", "frontend/**/*.ts", "scripts/**/*.ts", "scripts/**/*.mts", "evals/**/*.ts", "evals/**/*.mts"],
  "exclude": ["node_modules", "**/dist"]
}
