{
  "name": "sero",
  "version": "0.1.0",
  "private": true,
  "description": "Sero — 1:1 prep. CLI + web frontend.",
  "engines": {
    "node": ">=24 <25"
  },
  "scripts": {
    "dev": "concurrently -n api,web -c magenta,cyan --restart-tries -1 --restart-after 1500 \"cross-env API_PORT=3001 node backend/api/server.ts\" \"vite\"",
    "up": "powershell -ExecutionPolicy Bypass -File scripts/dev.ps1",
    "autostart:install": "powershell -ExecutionPolicy Bypass -File scripts/install-autostart.ps1",
    "autostart:uninstall": "powershell -ExecutionPolicy Bypass -File scripts/uninstall-autostart.ps1",
    "build": "vite build",
    "dev:customer": "vite --config frontend/vite.config.js",
    "build:customer": "vite build --config frontend/vite.config.js",
    "build:all": "npm run build && npm run build:customer",
    "start": "cross-env NODE_ENV=production node backend/api/server.ts",
    "cli": "node backend/cli.ts",
    "test": "node scripts/run-tests.js",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "typecheck:admin": "tsc --noEmit -p admin/tsconfig.json",
    "typecheck:customer": "tsc --noEmit -p frontend/tsconfig.json",
    "smoke": "node scripts/smoke-test.js",
    "eval": "node scripts/eval.js",
    "gate": "node scripts/gate.js",
    "replay": "node scripts/replay-regression.js",
    "prose": "node scripts/golden-prose-snapshot.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "rebuild-question-index": "node scripts/rebuild-question-index.js --prune",
    "build-map": "node scripts/build-repo-map.js",
    "logs:purge": "node scripts/purge-runs.ts",
    "errors:purge": "node scripts/purge-error-logs.js",
    "sweep": "node scripts/sweep.js"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@fontsource-variable/inter": "^5.0.21",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^26.0.0",
    "@types/pg": "^8.20.0",
    "autoprefixer": "^10.4.20",
    "concurrently": "^10.0.3",
    "cross-env": "^7.0.3",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.17.0",
    "globals": "^15.14.0",
    "gpt-tokenizer": "^3.4.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^6.0.3",
    "vite": "^6.0.3"
  },
  "dependencies": {
    "@fontsource-variable/bricolage-grotesque": "^5.2.10",
    "bcryptjs": "^3.0.3",
    "drizzle-orm": "^0.45.2",
    "lucide": "^1.23.0",
    "pg": "^8.22.0",
    "yaml": "^2.9.0"
  }
}
