{
  "name": "sero",
  "version": "0.1.0",
  "private": true,
  "description": "Sero — 1:1 prep. CLI + web frontend.",
  "scripts": {
    "dev": "concurrently -n api,web -c magenta,cyan \"cross-env API_PORT=3001 node frontend/server/server.js\" \"vite\"",
    "build": "vite build",
    "start": "cross-env NODE_ENV=production node frontend/server/server.js",
    "cli": "node cli.js",
    "test": "node scripts/run-tests.js",
    "lint": "eslint .",
    "smoke": "node smoke-test.js",
    "eval": "node scripts/eval.js",
    "gate": "node scripts/gate.js",
    "replay": "node scripts/replay-regression.js",
    "rebuild-question-index": "node scripts/rebuild-question-index.js --prune",
    "logs:purge": "node scripts/purge-logs.js",
    "sweep": "node scripts/sweep.js"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@fontsource-variable/inter": "^5.0.21",
    "autoprefixer": "^10.4.20",
    "concurrently": "^10.0.3",
    "cross-env": "^7.0.3",
    "eslint": "^9.17.0",
    "globals": "^15.14.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "vite": "^6.0.3"
  },
  "dependencies": {
    "yaml": "^2.9.0"
  }
}
